# DeepSeek API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 豆包星绘 (火山方舟 ARK) API Key
ARK_API_KEY=your_ark_api_key_here

# JWT 密钥（生产环境必须修改为随机强密钥）
JWT_SECRET=change-me-to-a-random-secret-in-production
# JWT 过期时间（小时）
JWT_EXPIRE_HOURS=72

# 管理员 Token（用于 /api/admin/* 接口）
ADMIN_TOKEN=change-me-to-a-secret-admin-token

# 允许的 CORS 来源
ALLOWED_ORIGINS=http://localhost:5678,http://127.0.0.1:5678
