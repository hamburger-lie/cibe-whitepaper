# ==============================================================
# CIBE 白皮书生成系统 — 环境变量模板
# 使用方式: cp .env.example .env 后，填入真实密钥
# ==============================================================

# 必填 —— DeepSeek API 密钥（文本生成）
# 申请: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 选填 —— 豆包星绘 (火山方舟 ARK) API 密钥（AI 配图）
# 申请: https://www.volcengine.com/product/doubao
# 未配置则配图功能降级为占位图
ARK_API_KEY=your_ark_api_key_here

# 强烈建议配置 —— Scrapfly 云爬虫 API 密钥
# 申请: https://scrapfly.io/  （注册即送免费额度）
# 用于绕过搜索引擎反爬、抓取任意网页
# 未配置则回退到直连（在反爬严格的网络环境会失败）
SCRAPFLY_API_KEY=your_scrapfly_api_key_here

# 选填 —— 联网研究预算模式：economy / balanced / deep / legacy
# economy≈6-8篇可用资料，balanced≈10篇可用资料，deep≈12-15篇可用资料
RESEARCH_BUDGET_MODE=balanced

# 选填 —— 单次白皮书联网研究上限，控制 Scrapfly 积分消耗
# balanced 默认约 30 次搜索 + 40 个候选页面抓取，优先凑满 10 篇可用资料
RESEARCH_MAX_SEARCH_REQUESTS=30
RESEARCH_MAX_FETCH_PAGES=40
RESEARCH_TARGET_REFERENCES=10

# 选填 —— Scrapfly 单次请求成本上限与缓存时间
# 搜索页通常 1-3 credits；普通文章页通常 1-5 credits。命中缓存不重复消耗抓取成本。
SCRAPFLY_COST_BUDGET_SEARCH=3
SCRAPFLY_COST_BUDGET_PAGE=5
SCRAPFLY_CACHE_TTL=604800

# 选填 —— CORS 允许的来源，逗号分隔
ALLOWED_ORIGINS=http://localhost:5678,http://127.0.0.1:5678

# 强烈建议修改 —— 后台登录账号密码
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=change_this_password_before_deploy
AUTH_SECRET=change_this_random_session_secret
AUTH_SESSION_TTL=86400
# HTTPS 部署后建议设为 true
AUTH_COOKIE_SECURE=false
# SQLite 用户表和任务队列
APP_DB_PATH=data/app.db
GENERATION_WORKERS=2

# 选填 —— 反思增强开关（true/false）
ENABLE_REFLECTION=true

# 选填 —— 联网搜索开关（true/false）
ENABLE_WEB_SEARCH=true

# 选填 —— 数据联网核查开关（true/false）
ENABLE_DATA_VERIFICATION=false

# 选填 —— 反思记录存储路径
REFLECTION_STORAGE_PATH=reflections.json

# 选填 —— 联网搜索超时（秒）
WEB_SEARCH_TIMEOUT=10
